<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuração de segurança de rede — OrganiStuda
  - Permite apenas HTTPS em produção
  - Permite HTTP apenas para localhost (desenvolvimento)
  - Bloqueia tráfego não seguro para domínios externos
-->
<network-security-config>

    <!-- Domínios de produção: apenas HTTPS -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Localhost: permite HTTP para desenvolvimento/WebView local -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">localhost</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">10.0.2.2</domain>
    </domain-config>

</network-security-config>

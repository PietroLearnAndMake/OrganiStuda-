<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- API 27+: suporte a ícones escuros na status bar e nav bar -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#6c2cff</item>
        <item name="colorPrimaryDark">#5a1fe0</item>
        <item name="colorAccent">#6c2cff</item>

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:fitsSystemWindows">false</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">@android:color/black</item>

        <!-- API 27: ícones brancos na nav bar (para fundo escuro) -->
        <item name="android:windowLightNavigationBar">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
    </style>

</resources>

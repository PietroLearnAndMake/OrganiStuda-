<?xml version="1.0" encoding="utf-8"?>
<!--
  Widget de Streak — Novo Design Moderno
  Fundo: Preto Profundo | Texto: "Sua sequência está a X Dias" | Emoji: 👀
-->
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_dark"
    android:padding="12dp">

    <!-- Container centralizado para o conteúdo -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Texto fixo superior -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sua sequência está a"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:alpha="0.9"
            android:layout_marginBottom="2dp" />

        <!-- Contador dinâmico (X Dias) -->
        <TextView
            android:id="@+id/widget_streak_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 Dias"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Emoji de Olhinho (👀) estilo iPhone -->
        <TextView
            android:id="@+id/widget_fire_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👀"
            android:textSize="40sp" />

    </LinearLayout>

    <!-- Informações secundárias discretas no rodapé -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center">

        <TextView
            android:id="@+id/widget_best_streak"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recorde: 0"
            android:textColor="#9B6DFF"
            android:textSize="10sp"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/widget_questions"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 questões"
            android:textColor="#AAAAAA"
            android:textSize="10sp" />
            
        <!-- TextView oculto para compatibilidade com o Provider -->
        <TextView
            android:id="@+id/widget_motivation"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />

    </LinearLayout>

</RelativeLayout>

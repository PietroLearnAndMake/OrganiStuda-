# Variáveis de Ambiente - OrganiStuda v2.0.0
# Copie este arquivo para .env.local e preencha com seus valores

# Sentry - Monitoramento de Erros
VITE_SENTRY_DSN=https://seu-dsn@sentry.io/seu-projeto
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0
VITE_SENTRY_DEBUG=false

# Ambiente
VITE_ENVIRONMENT=development

# Notificações
VITE_NOTIFICATIONS_ENABLED=true

# Performance Monitoring
VITE_PERFORMANCE_MONITORING=true

# Backup
VITE_AUTO_BACKUP_ENABLED=true
VITE_AUTO_BACKUP_INTERVAL=86400000

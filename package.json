{
  "name": "organistuda",
  "private": true,
  "version": "4.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest",
    "cap:sync": "cap sync android",
    "cap:build": "vite build && cap sync android",
    "sync:massive": "tsx scripts/ingestor.ts && npx cap sync android",
    "build:android": "cd android && ./gradlew assembleDebug",
    "build:android:release": "cd android && ./gradlew assembleRelease",
    "db:migrate": "drizzle-kit generate && drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "ingest": "tsx scripts/ingestor-master.ts",
    "ingest:watch": "tsx watch scripts/ingestor-master.ts"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^8.0.1",
    "@capacitor/android": "~8.2.0",
    "@capacitor/core": "~8.2.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.90.21",
    "@trpc/client": "^11.12.0",
    "@trpc/react-query": "^11.12.0",
    "@trpc/server": "^11.12.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.13.6",
    "cookie": "^1.1.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.44.7",
    "expo-secure-store": "^55.0.8",
    "jose": "^6.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "mysql2": "^3.16.0",
    "pg": "^8.13.0",
    "postgres": "^3.4.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "superjson": "^2.2.6",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@capacitor/cli": "~8.2.0",
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.0.3",
    "eslint-config-expo": "^55.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "tailwindcss": "^4.1.14",
    "terser": "^5.46.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
